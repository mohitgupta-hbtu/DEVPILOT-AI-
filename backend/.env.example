# ======================================================
# DevPilot AI — Backend Environment Configuration
# ======================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ======================================================

# ── Database ──────────────────────────────────────────
# Default: SQLite (no setup needed for local dev)
DATABASE_URL=sqlite+aiosqlite:///./devpilot.db

# ── GitHub OAuth (optional, for user login) ──────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/auth/callback

# ── GitHub Personal Access Token ─────────────────────
# Required for fetching private repos & avoiding rate limits.
# Generate at: https://github.com/settings/tokens
# Scopes needed: repo (read)
GITHUB_TOKEN=

# ── AI Provider Keys (optional) ─────────────────────
# Gemini: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ── JWT Auth ─────────────────────────────────────────
JWT_SECRET=change_me_to_a_random_string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7

# ── CORS & Environment ──────────────────────────────
CORS_ORIGINS=http://localhost:5173
ENVIRONMENT=development
FRONTEND_URL=http://localhost:5173
