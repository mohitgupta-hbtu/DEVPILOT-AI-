# ========================================================
# DEVPILOT AI - BACKEND ENVIRONMENT CONFIGURATION
# ========================================================

# Database Setup (Leave as default for local SQLite testing)
DATABASE_URL=sqlite+aiosqlite:///./devpilot.db

# GitHub Authentication (Required for bypassing 60 req/hr limits)
GITHUB_CLIENT_ID=your_github_oauth_app_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret
# To create these: Go to GitHub Settings > Developer Settings > OAuth Apps

# AI Engine API Keys (Supply at least one to bypass static default fallback)
GEMINI_API_KEY=your_gemini_key_here
# OPENROUTER_API_KEY=your_openrouter_key_here

# Security
JWT_SECRET=generate_a_random_secure_32_char_string_here
FRONTEND_URL=http://localhost:8080
